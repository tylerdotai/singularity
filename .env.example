# Copy this file to .env and fill in values
# Singularity Environment Variables

# === REQUIRED (must be set before running production server) ===
SINGULARITY_JWT_SECRET=your-jwt-secret-here
SINGULARITY_ENCRYPTION_KEY=your-encryption-key-here

# === OPTIONAL (for provider API keys — only needed when using that provider) ===
OPENAI_API_KEY=your-openai-api-key
MINIMAX_API_KEY=your-minimax-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# === OPTIONAL (overrides) ===
SINGULARITY_HOME=~/.singularity
