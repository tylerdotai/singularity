	"type": "module",
	"workspaces": [
		"packages/singularity-core",
		"packages/singularity-loop",
		"packages/singularity-approvals",
		"packages/singularity-cli",
		"packages/singularity-config",
		"packages/singularity-engine",
		"packages/singularity-llm",
